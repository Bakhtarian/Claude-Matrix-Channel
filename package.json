{
  "name": "claude-channel-matrix",
  "description": "Matrix/Element messaging channel for Claude Code — MCP server with E2EE, access control, and device verification",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "keywords": [
    "claude",
    "claude-code",
    "matrix",
    "element",
    "mcp",
    "mcp-server",
    "chatbot",
    "messaging",
    "e2ee",
    "encryption",
    "channel",
    "bot",
    "ai",
    "anthropic"
  ],
  "type": "module",
  "bin": "./server.ts",
  "scripts": {
    "start": "${MATRIX_RUNTIME:-bun} server.ts",
    "check": "bunx tsc --noEmit && bunx biome check .",
    "test": "bun test",
    "format": "bunx biome check --write ."
  },
  "dependencies": {
    "@matrix-org/matrix-sdk-crypto-wasm": "^18.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fake-indexeddb": "^6.2.5",
    "matrix-bot-sdk": "^0.7.0"
  },
  "trustedDependencies": [
    "@matrix-org/matrix-sdk-crypto-wasm"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "bun-types": "^1.3.11"
  }
}
